# Copia este archivo como .env.local y rellena los valores
# En Vercel: Settings > Environment Variables

# URL del Web App de Google Apps Script
# Formato: https://script.google.com/macros/s/TU_ID_DEPLOYMENT/exec
GAS_URL=https://script.google.com/macros/s/AQUI_VA_TU_ID/exec

# Token secreto de seguridad
# Debe ser el mismo que pusiste en Propiedades del script de GAS como "GAS_SECRET"
# Puedes generar uno aleatorio: openssl rand -hex 32
GAS_SECRET=pon_aqui_un_token_secreto_largo
